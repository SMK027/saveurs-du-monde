      "description": "Recette de ratatouille provençale facile, idéale pour un plat principal végétarien.",
      "image": "https://images.unsplash.com/photo-1572453800999-e8d2d1589b7c?w=600&q=80",
      "recipeCategory": "Plat Principal",
      "recipeCuisine": "Française",
      "recipeYield": "4 portions",
      "totalTime": "PT50M",
      "recipeIngredient": [
        "2 courgettes",
        "2 aubergines",
        "4 tomates",
        "2 poivrons rouges",
        "1 oignon",
        "4 gousses d'ail",
        "4 c. à soupe d'huile d'olive"
      ],
      "recipeInstructions": [
        {
          "@type": "HowToStep",
          "text": "Couper les légumes puis faire revenir l'oignon et l'ail dans l'huile d'olive."
        },
        {
          "@type": "HowToStep",
          "text": "Ajouter poivrons, aubergines et courgettes, puis mélanger régulièrement."
        },
        {
          "@type": "HowToStep",
          "text": "Incorporer les tomates, les herbes, assaisonner, puis laisser mijoter."
        },
        {
          "@type": "HowToStep",
          "text": "Servir chaud avec du basilic frais."
        }
